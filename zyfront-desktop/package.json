{
  "name": "zyfront-desktop",
  "version": "0.1.0",
  "config": {
    "electron_builder_binaries_mirror": "https://npmmirror.com/mirrors/electron-builder-binaries/"
  },
  "productName": "ZyTrader Desktop",
  "main": "main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve zyfront-desktop-web --host 127.0.0.1 --port 4200 --open",
    "serve": "ng serve zyfront-desktop-web --host 127.0.0.1 --port 4200",
    "build": "npm run verify:utf8 && ng build zyfront-desktop-web --base-href ./ && electron .",
    "electron:run": "electron .",
    "pack": "cross-env ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --dir",
    "dist": "cross-env ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --win",
    "verify:utf8": "node scripts/verify-source-utf8.mjs",
    "watch": "ng build zyfront-desktop-web --base-href ./ --watch",
    "dev": "concurrently -k \"npm:serve\" \"npm:electron:dev\"",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:start": "npm run build && electron .",
    "electron:build": "npm run build && cross-env ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder",
    "check": "node scripts/check.mjs",
    "api:check": "node scripts/api-check.mjs",
    "data:check": "node scripts/data-check.mjs",
    "ui:check": "node scripts/ui-check.mjs"
  },
  "build": {
    "appId": "com.zyfront.desktop",
    "npmRebuild": false,
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.6",
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/platform-browser": "^21.2.6",
    "@angular/platform-browser-dynamic": "^21.2.6",
    "@angular/router": "^21.2.6",
    "@ant-design/icons-angular": "^21.0.0",
    "@ctrl/tinycolor": "^4.2.0",
    "@monaco-editor/loader": "^1.7.0",
    "cors": "^2.8.6",
    "d3": "^7.9.0",
    "d3-sankey": "^0.12.3",
    "echarts": "^6.0.0",
    "express": "^5.2.1",
    "marked": "^17.0.0",
    "moment": "^2.30.1",
    "monaco-editor": "^0.55.1",
    "ng-zorro-antd": "^21.2.1",
    "ngx-markdown": "^21.2.0",
    "node-pty": "^1.1.0",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uuid": "^14.0.0",
    "vis-data": "^8.0.3",
    "vis-network": "^10.0.2",
    "vis-timeline": "^8.5.0",
    "ws": "^8.20.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-search": "^0.13.0",
    "zone.js": "~0.15.0",
    "zyfront-core": "file:../zyfront-core"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.6",
    "@types/d3": "^7.4.3",
    "@types/d3-sankey": "^0.12.5",
    "@types/jasmine": "~5.1.0",
    "@types/plist": "^3.0.5",
    "@types/prismjs": "^1.26.6",
    "@types/uuid": "^10.0.0",
    "@types/verror": "^1.10.11",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "pptxgenjs": "^4.0.1",
    "typescript": "~5.9.2"
  }
}
